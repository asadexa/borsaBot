# ─────────────────────────────────────────────
# BorsaBot Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Binance ──────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true                    # true = testnet, false = live

# ── Interactive Brokers ───────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497                            # 7497 = paper, 7496 = live
IB_CLIENT_ID=1

# ── MetaTrader 5 ─────────────────────────────
MT5_ACCOUNT=0
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=your_mt5_server_here

# ── TimescaleDB ───────────────────────────────
TIMESCALE_DSN=postgresql://borsabot:borsabot@localhost:5432/borsabot

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ZeroMQ ────────────────────────────────────
ZMQ_PUB_ADDR=tcp://127.0.0.1:5555
ZMQ_SUB_ADDR=tcp://127.0.0.1:5555

# ── Trading Parameters ────────────────────────
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT
NAV_USD=100000                          # total account NAV in USD
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
